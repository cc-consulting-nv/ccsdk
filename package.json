{
  "name": "@closedcircuitlogin/cc-platform-sdk",
  "version": "1.0.0",
  "description": "Cache-aware CC API SDK using Dexie and TanStack Query core.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -b",
    "clean": "rimraf dist",
    "prepublishOnly": "npm run clean && npm run build",
    "lint": "echo \"lint not configured for sdk\"",
    "test": "node --test tests/httpClient.test.js",
    "test:integration": "node ./tests/integration.js",
    "docs": "typedoc --options typedoc.html.json",
    "docs:html": "typedoc --options typedoc.html.json",
    "docs:md": "typedoc --options typedoc.md.json"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/closedcircuitlogin/cc-platform-sdk.git"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "keywords": [
    "sdk",
    "api",
    "closedcircuit",
    "tanstack-query",
    "dexie",
    "offline-first"
  ],
  "author": "ClosedCircuit",
  "license": "UNLICENSED",
  "bugs": {
    "url": "https://github.com/closedcircuitlogin/cc-platform-sdk/issues"
  },
  "homepage": "https://github.com/closedcircuitlogin/cc-platform-sdk#readme",
  "dependencies": {
    "@msgpack/msgpack": "^3.1.3",
    "@tanstack/query-core": "^5.90.11",
    "dexie": "^4.2.1"
  },
  "devDependencies": {
    "rimraf": "^5.0.5",
    "typedoc": "^0.28.15",
    "typedoc-plugin-markdown": "^4.9.0",
    "typescript": "^5.6.3"
  }
}
